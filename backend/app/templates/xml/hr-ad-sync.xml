<?xml version="1.0" encoding="UTF-8"?>
<streamworks-config xmlns="http://streamworks.arvato.com/v1">
  <metadata>
    <name>HR-ActiveDirectory-Sync</name>
    <description>Employee data synchronization from HR System to Active Directory</description>
    <version>1.0</version>
    <created>2025-01-15T10:30:00Z</created>
    <category>HR Integration</category>
  </metadata>
  
  <stream id="hr_to_ad_employees" type="realtime">
    <source system="HR_System" format="JSON">
      <connection-string>https://hr.company.com/api/v2/</connection-string>
      <authentication type="bearer-token">
        <token>${HR_API_TOKEN}</token>
      </authentication>
      <endpoint>/employees</endpoint>
      <polling-interval>PT5M</polling-interval>
    </source>
    
    <target system="ActiveDirectory" format="LDAP">
      <connection-string>ldaps://ad.company.com:636</connection-string>
      <authentication type="kerberos">
        <principal>streamworks@COMPANY.COM</principal>
        <keytab>/etc/streamworks/streamworks.keytab</keytab>
      </authentication>
      <base-dn>OU=Users,DC=company,DC=com</base-dn>
    </target>
    
    <mapping>
      <field source="employee_id" target="employeeID" type="string" required="true"/>
      <field source="username" target="sAMAccountName" type="string" required="true">
        <transform type="lowercase"/>
      </field>
      <field source="email" target="mail" type="string" required="true"/>
      <field source="first_name" target="givenName" type="string" required="true"/>
      <field source="last_name" target="sn" type="string" required="true"/>
      <field source="display_name" target="displayName" type="string" required="true"/>
      <field source="department" target="department" type="string" required="false"/>
      <field source="title" target="title" type="string" required="false"/>
      <field source="manager_email" target="manager" type="string" required="false">
        <transform type="lookup">
          <lookup-source>ad_users_by_email</lookup-source>
        </transform>
      </field>
      <field source="phone" target="telephoneNumber" type="string" required="false"/>
      <field source="office_location" target="physicalDeliveryOfficeName" type="string" required="false"/>
      <field source="status" target="userAccountControl" type="integer" required="true">
        <transform type="conditional">
          <condition value="active">512</condition>
          <condition value="inactive">514</condition>
          <default>514</default>
        </transform>
      </field>
    </mapping>
    
    <schedule type="realtime">
      <event-driven>true</event-driven>
      <change-detection>
        <fields>status,department,title,manager_email</fields>
        <checksum>true</checksum>
      </change-detection>
    </schedule>
    
    <error-handling>
      <retry-policy max-attempts="5" backoff="linear">
        <initial-delay>PT10S</initial-delay>
        <increment>PT10S</increment>
      </retry-policy>
      <dead-letter-queue enabled="true">
        <destination>hr-ad-dlq</destination>
        <retention-days>30</retention-days>
      </dead-letter-queue>
      <notifications>
        <email>hr-admins@company.com</email>
        <teams-webhook>${TEAMS_WEBHOOK_URL}</teams-webhook>
      </notifications>
    </error-handling>
    
    <security>
      <encryption-in-transit>true</encryption-in-transit>
      <field-encryption>
        <field name="social_security_number" algorithm="AES-256"/>
      </field-encryption>
      <audit-logging>true</audit-logging>
    </security>
  </stream>
</streamworks-config>