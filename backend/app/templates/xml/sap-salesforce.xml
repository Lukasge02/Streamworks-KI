<?xml version="1.0" encoding="UTF-8"?>
<streamworks-config xmlns="http://streamworks.arvato.com/v1">
  <metadata>
    <name>SAP-Salesforce-Sync</name>
    <description>Standard customer data synchronization from SAP ERP to Salesforce CRM</description>
    <version>1.0</version>
    <created>2025-01-15T10:30:00Z</created>
    <category>CRM Integration</category>
  </metadata>
  
  <stream id="sap_to_sf_customers" type="batch">
    <source system="SAP_ERP" format="JSON">
      <connection-string>sap://erp.company.com:3300/CLIENT/100</connection-string>
      <authentication type="oauth2">
        <client-id>${SAP_CLIENT_ID}</client-id>
        <client-secret>${SAP_CLIENT_SECRET}</client-secret>
      </authentication>
      <query>
        <table>KNA1</table>
        <fields>KUNNR,NAME1,NAME2,STRAS,ORT01,PSTLZ,LAND1,TELF1,SMTP_ADDR</fields>
        <where>ERDAT >= '${LAST_RUN_DATE}'</where>
      </query>
    </source>
    
    <target system="Salesforce" format="JSON">
      <connection-string>https://company.salesforce.com/services/data/v59.0/</connection-string>
      <authentication type="oauth2">
        <client-id>${SF_CLIENT_ID}</client-id>
        <client-secret>${SF_CLIENT_SECRET}</client-secret>
        <username>${SF_USERNAME}</username>
        <password>${SF_PASSWORD}</password>
      </authentication>
      <object>Account</object>
      <operation>upsert</operation>
      <external-id>SAP_Customer_ID__c</external-id>
    </target>
    
    <mapping>
      <field source="KUNNR" target="SAP_Customer_ID__c" type="string" required="true"/>
      <field source="NAME1" target="Name" type="string" required="true"/>
      <field source="NAME2" target="Account_Name_2__c" type="string" required="false"/>
      <field source="STRAS" target="BillingStreet" type="string" required="false"/>
      <field source="ORT01" target="BillingCity" type="string" required="false"/>
      <field source="PSTLZ" target="BillingPostalCode" type="string" required="false"/>
      <field source="LAND1" target="BillingCountry" type="string" required="false">
        <transform type="lookup">
          <lookup-table>country_codes.json</lookup-table>
        </transform>
      </field>
      <field source="TELF1" target="Phone" type="string" required="false"/>
      <field source="SMTP_ADDR" target="Email__c" type="string" required="false"/>
    </mapping>
    
    <schedule type="daily">
      <cron>0 2 * * *</cron>
      <timezone>Europe/Berlin</timezone>
      <max-runtime>PT2H</max-runtime>
    </schedule>
    
    <error-handling>
      <retry-policy max-attempts="3" backoff="exponential">
        <initial-delay>PT30S</initial-delay>
        <max-delay>PT5M</max-delay>
      </retry-policy>
      <dead-letter-queue enabled="true">
        <destination>sap-sf-dlq</destination>
        <retention-days>7</retention-days>
      </dead-letter-queue>
      <notifications>
        <email>streamworks-admin@company.com</email>
        <webhook>https://monitoring.company.com/webhooks/streamworks</webhook>
      </notifications>
    </error-handling>
    
    <performance>
      <batch-size>1000</batch-size>
      <parallel-threads>4</parallel-threads>
      <memory-limit>2GB</memory-limit>
    </performance>
  </stream>
</streamworks-config>