## 🔧 **Praktische Implementation**

### **Frontend Permission-basierte Komponenten**
```typescript
// RoleBasedComponent.tsx
interface RoleBasedComponentProps {
  requiredPermission: string;
  fallbackComponent?: React.ReactNode;
  children: React.ReactNode;
}

const RoleBasedComponent: React.FC<RoleBasedComponentProps> = ({
  requiredPermission,
  fallbackComponent,
  children
}) => {
  const { user } = useAuth();
  const hasPermission = checkPermission(user, requiredPermission);

  if (!hasPermission) {
    return fallbackComponent || <AccessDeniedMessage permission={requiredPermission} />;
  }

  return <>{children}</>;
};

// Usage in Chat Interface:
const ChatInterface = () => {
  return (
    <div className="chat-interface">
      {/* Q&A always visible (basic permission) */}
      <ServiceTab 
        icon="🤖" 
        label="Q&A Assistant" 
        active={service === 'qa'}
        onClick={() => setService('qa')}
      />

      {/* XML Generator - only for certain roles */}
      <RoleBasedComponent 
        requiredPermission="xml:read"
        fallbackComponent={
          <ServiceTab 
            icon="🔒" 
            label="XML Generator (No Access)" 
            disabled 
          />
        }
      >
        <ServiceTab 
          icon="📄" 
          label="XML Generator" 
          active={service === 'xml'}
          onClick={() => setService('xml')}
        />
      </RoleBasedComponent>

      {/* API Commands - only for admins */}
      <RoleBasedComponent requiredPermission="api:execute">
        <ServiceTab 
          icon="🔌" 
          label="API Commands" 
          active={service === 'api'}
          onClick={() => setService('api')}
        />
      </RoleBasedComponent>
    </div>
  );
};
```

