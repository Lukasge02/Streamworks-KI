### **Permission-based API Responses**
```python
# backend/app/api/chat.py
@router.post("/chat/")
async def chat_endpoint(
    request: ChatRequest,
    current_user: User = Depends(get_current_user)
):
    # Check service permission
    if request.service_type == "api_interaction":
        if not check_permission(current_user, "api:execute"):
            return ChatResponse(
                response="🚫 API-Befehle sind für deine Rolle nicht verfügbar. Wende dich an deinen Administrator.",
                service_type="error",
                available_services=get_available_services(current_user)
            )
    
    # Process message with user context
    response = await unified_chat_service.process_message(
        message=request.message,
        user=current_user,
        service_type=request.service_type
    )
    
    return response

def get_available_services(user: User) -> List[str]:
    """Return list of available services for user"""
    services = []
    
    if check_permission(user, "qa:read"):
        services.append("qa")
    if check_permission(user, "xml:read"):
        services.append("xml_generation")
    if check_permission(user, "api:execute"):
        services.append("api_interaction")
    
    return services
```

