### **3. 🔐 Permission & Authentication System**
```python
# app/core/auth.py
from fastapi import Depends, HTTPException, status
from fastapi.security import OAuth2PasswordBearer
from jose import JWTError, jwt
from typing import Optional, List

oauth2_scheme = OAuth2PasswordBearer(tokenUrl="token")

class User:
    def __init__(self, username: str, role: UserRole, permissions: List[str]):
        self.username = username
        self.role = role
        self.permissions = permissions
        self.tenant_id = self.determine_tenant()

class UserRole(Enum):
    SUPER_ADMIN = "super_admin"
    ADMIN = "admin"
    STREAMWORKS_TEAM = "streamworks_team"
    INTERNAL_CUSTOMER = "internal_customer"
    EXTERNAL_CUSTOMER = "external_customer"

class PermissionManager:
    """Advanced permission management"""
    
    ROLE_PERMISSIONS = {
        UserRole.SUPER_ADMIN: [
            "qa:read", "qa:write",
            "xml:read", "xml:write", "xml:deploy",
            "api:read", "api:write", "api:execute",
            "admin:users", "admin:system", "admin:analytics"
        ],
        UserRole.ADMIN: [
            "qa:read", "qa:write",
            "xml:read", "xml:write", 
            "api:read", "api:execute:limited",
            "admin:users:limited", "admin:analytics"
        ],
        UserRole.STREAMWORKS_TEAM: [
            "qa:read", "qa:write",
            "xml:read", "xml:write:templates",
            "api:read"
        ],
        UserRole.INTERNAL_CUSTOMER: [
            "qa:read",
            "xml:read"
        ],
        UserRole.EXTERNAL_CUSTOMER: [
            "qa:read:public"  # Only public documentation
        ]
    }
    
    def check_permission(self, user: User, required_permission: str) -> bool:
        """
        Check if user has required permission
        """
        user_permissions = self.ROLE_PERMISSIONS.get(user.role, [])
        
        # Exact match
        if required_permission in user_permissions:
            return True
        
        # Wildcard permissions (e.g., "api:*" covers "api:read")
        for perm in user_permissions:
            if perm.endswith("*") and required_permission.startswith(perm[:-1]):
                return True
        
        return False

# Dependency for protecting endpoints
async def get_current_user(token: str = Depends(oauth2_scheme)) -> User:
    """Extract user from JWT token"""
    try:
        payload = jwt.decode(token, settings.SECRET_KEY, algorithms=[settings.ALGORITHM])
        username: str = payload.get("sub")
        if username is None:
            raise credentials_exception
    except JWTError:
        raise credentials_exception
    
    user = await get_user_from_db(username)
    if user is None:
        raise credentials_exception
    return user

def require_permission(permission: str):
    """Decorator for requiring specific permissions"""
    def decorator(func):
        async def wrapper(*args, **kwargs):
            user = kwargs.get('current_user')
            if not PermissionManager().check_permission(user, permission):
                raise HTTPException(
                    status_code=status.HTTP_403_FORBIDDEN,
                    detail=f"Insufficient permissions. Required: {permission}"
                )
            return await func(*args, **kwargs)
        return wrapper
    return decorator
```

