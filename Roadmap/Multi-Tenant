# Tenant-based data filtering
class TenantDataFilter:
    def apply_tenant_filter(self, query: str, user: User) -> str:
        """Apply tenant-specific data filtering"""
        
        tenant_filters = {
            "external_customer": "AND visibility='public'",
            "internal_customer": "AND (visibility='public' OR visibility='internal')",
            "streamworks_team": "AND (visibility != 'admin_only')",
            "admin": "",  # No restrictions
            "super_admin": ""  # No restrictions
        }
        
        filter_clause = tenant_filters.get(user.role, "AND visibility='public'")
        return f"{query} {filter_clause}"
