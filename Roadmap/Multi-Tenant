```python
# app/services/unified_chat_service.py
from enum import Enum
from typing import Dict, Any, List, Optional

class ServiceType(Enum):
    QA = "qa"
    XML_GENERATION = "xml_generation"
    API_INTERACTION = "api_interaction"

class UnifiedChatService:
    def __init__(self):
        self.rag_service = RAGService()
        self.xml_service = XMLGeneratorService()
        self.api_service = StreamWorksAPIService()  # NEW
        self.intent_classifier = IntentClassifier()  # NEW
        
    async def process_message(
        self, 
        message: str, 
        user: User, 
        context: Optional[Dict[str, Any]] = None
    ) -> ChatResponse:
        """
        Universal message processor that routes to appropriate service
        """
        # 1. Classify user intent
        intent = await self.intent_classifier.classify(message, context)
        
        # 2. Check permissions
        if not self.has_permission(user, intent.service_type):
            return self.create_permission_denied_response(user, intent.service_type)
        
        # 3. Route to appropriate service
        if intent.service_type == ServiceType.QA:
            return await self.handle_qa_request(message, user, context)
        elif intent.service_type == ServiceType.XML_GENERATION:
            return await self.handle_xml_request(message, user, context)
        elif intent.service_type == ServiceType.API_INTERACTION:
            return await self.handle_api_request(message, user, context)
        
    async def handle_api_request(self, message: str, user: User, context: Dict) -> ChatResponse:
        """
        Handle StreamWorks API interactions
        """
        # Parse API request from natural language
        api_request = await self.parse_api_intent(message)
        
        # Execute API call with user permissions
        result = await self.api_service.execute_request(api_request, user)
        
        # Format response for chat
        return self.format_api_response(result)

class IntentClassifier:
    """AI-powered intent classification"""
    
    def __init__(self):
        self.patterns = {
            ServiceType.QA: [
                "was ist", "wie funktioniert", "erkläre", "hilfe",
                "what is", "how does", "explain", "help"
            ],
            ServiceType.XML_GENERATION: [
                "erstelle xml", "generiere batch", "create xml", "generate",
                "xml für", "batch job", "stream"
            ],
            ServiceType.API_INTERACTION: [
                "starte job", "stoppe", "status von", "start job", "stop",
                "api call", "execute", "run"
            ]
        }
    
    async def classify(self, message: str, context: Optional[Dict] = None) -> Intent:
        """
        Classify user intent using LLM + pattern matching
        """
        # Use Mistral for intelligent classification
        classification_prompt = f"""
        Klassifiziere diese Nachricht in eine Kategorie:
        1. qa - Fragen und Antworten
        2. xml_generation - XML/Batch Job Erstellung  
        3. api_interaction - StreamWorks API Calls
        
        Nachricht: "{message}"
        Kontext: {context or {}}
        
        Antwort nur mit der Kategorie:
        """
        
        result = await self.mistral_service.generate(classification_prompt)
        service_type = self.parse_classification_result(result)
        
        return Intent(
            service_type=service_type,
            confidence=0.8,  # Could be enhanced with ML confidence
            extracted_params=self.extract_parameters(message, service_type)
        )
```

### **2. 🔌 StreamWorks API Service**
```python
# app/services/streamworks_api_service.py
import httpx
from typing import Dict, Any, List
from app.models.user import User
from app.core.permissions import check_api_permission

class StreamWorksAPIService:
    def __init__(self):
        self.base_url = settings.STREAMWORKS_API_URL
        self.client = httpx.AsyncClient()
        self.api_methods = self.load_api_definitions()
    
    async def execute_request(
        self, 
        api_request: APIRequest, 
        user: User
    ) -> APIResponse:
        """
        Execute StreamWorks API request with permission checking
        """
        # 1. Permission check
        if not check_api_permission(user, api_request.endpoint):
            raise PermissionError(f"User {user.username} lacks permission for {api_request.endpoint}")
        
        # 2. Parameter validation
        validated_params = self.validate_parameters(api_request)
        
        # 3. Execute API call
        try:
            response = await self.client.request(
                method=api_request.method,
                url=f"{self.base_url}/{api_request.endpoint}",
                json=validated_params,
                headers={"Authorization": f"Bearer {self.get_service_token()}"}
            )
            
            # 4. Log API usage
            await self.log_api_usage(user, api_request, response.status_code)
            
            return APIResponse(
                success=response.status_code < 400,
                data=response.json(),
                status_code=response.status_code
            )
            
        except Exception as e:
            logger.error(f"API call failed: {e}")
            return APIResponse(
                success=False,
                error=str(e),
                status_code=500
            )
    
    def parse_natural_language_to_api(self, message: str) -> APIRequest:
        """
        Convert natural language to API request
        """
        # Examples:
        # "Starte Job ABC123" -> POST /jobs/ABC123/start
        # "Zeige Status von Job XYZ" -> GET /jobs/XYZ/status  
        # "Stoppe alle Jobs in Queue DEV" -> POST /queues/DEV/stop-all
        
        patterns = {
            r"starte job (\w+)": ("POST", "jobs/{}/start"),
            r"stoppe job (\w+)": ("POST", "jobs/{}/stop"),
            r"status von job (\w+)": ("GET", "jobs/{}/status"),
            r"liste jobs in (\w+)": ("GET", "queues/{}/jobs"),
        }
        
        for pattern, (method, endpoint_template) in patterns.items():
            match = re.search(pattern, message.lower())
            if match:
                endpoint = endpoint_template.format(*match.groups())
                return APIRequest(method=method, endpoint=endpoint)
        
        # Fallback: Use LLM for complex parsing
        return self.llm_parse_api_request(message)

class APIRequestParser:
    """Advanced API request parsing with LLM"""
    
    async def parse(self, message: str, available_apis: List[Dict]) -> APIRequest:
        """
        Use LLM to parse complex API requests
        """
        prompt = f"""
        Du bist ein StreamWorks API Assistent. Konvertiere diese Nachricht in einen API Call:
        
        Verfügbare APIs:
        {self.format_api_documentation(available_apis)}
        
        Benutzer-Nachricht: "{message}"
        
        Antworte mit JSON:
        {{
            "method": "GET|POST|PUT|DELETE",
            "endpoint": "api/endpoint/path",
            "parameters": {{}},
            "confidence": 0.0-1.0
        }}
        """
        
        result = await self.mistral_service.generate(prompt)
        return self.parse_llm_response(result)
