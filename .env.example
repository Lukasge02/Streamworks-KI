# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBED_MODEL=text-embedding-3-large

# PostgreSQL (Docker setzt DATABASE_URL automatisch, hier nur fuer lokale Entwicklung)
DATABASE_URL=
POSTGRES_USER=streamworks
POSTGRES_PASSWORD=streamworks123

# Qdrant (Docker ueberschreibt automatisch mit http://qdrant:6333)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=streamworks

# MinIO (Docker ueberschreibt automatisch mit minio:9000)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=streamworks
MINIO_SECRET_KEY=streamworks123
MINIO_BUCKET=documents
MINIO_SECURE=false

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# CORS (kommasepariert -- alle Origins von denen das Frontend aufgerufen wird)
# Lokal: http://localhost:3000
# Server: nicht noetig wenn Nginx alles auf gleiche Origin proxied
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend Backend-URL (die URL unter der das Backend EXTERN erreichbar ist)
# Lokal: http://localhost:8000
# Server mit Nginx: /api (relative URL, gleiche Origin)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Environment (development / production)
ENVIRONMENT=production
