apyrus_780/Papyrus%20Dokumente/IT_Bereich/User%20Helpdesk/Organisation/publ=
ic" rel=3D"nofollow">https://bertelsmann.sharepoint.com/sites/bportal_team_=
papyrus_780/Papyrus%20Dokumente/Forms/AllItems.aspx?id=3D/sites/bportal_tea=
m_papyrus_780/Papyrus%20Dokumente/IT_Bereich/User%20Helpdesk/Organisation/p=
ublic/Ticket-Knigge.pdf&amp;parent=3D/sites/bportal_team_papyrus_780/Papyru=
s%20Dokumente/IT_Bereich/User%20Helpdesk/Organisation/public</a></p>
<p><a href=3D"/wiki/download/attachments/329746050/Ticketqualit%C3%A4t_OM03=
0719.pptx?version=3D1&amp;modificationDate=3D1573823877789&amp;cacheVersion=
=3D1&amp;api=3Dv2" data-linked-resource-id=3D"329751379" data-linked-resour=
ce-version=3D"1" data-linked-resource-type=3D"attachment" data-linked-resou=
rce-default-alias=3D"Ticketqualit=C3=A4t_OM030719.pptx" data-nice-type=3D"M=
icrosoft PowerPoint Presentation" data-linked-resource-content-type=3D"appl=
ication/vnd.openxmlformats-officedocument.presentationml.presentation" data=
-linked-resource-container-id=3D"329746050" data-linked-resource-container-=
version=3D"57">Ticketqualit=C3=A4t_OM030719.pptx</a></p>
<h1 id=3D"id-00Allgemeines-Teamorganisation-Changeerstellung">Changeerstell=
ung</h1>
<div class=3D"table-wrap">
<table class=3D"wrapped confluenceTable">
<colgroup>
<col>
<col>
<col>
</colgroup>
<tbody>
<tr>
<th class=3D"confluenceTh">Servicename</th>
<td class=3D"confluenceTd"><strong>streamworks prod</strong></td>
<td class=3D"confluenceTd"><strong>streamworks prod internal</strong></td>
</tr>
<tr>
<th class=3D"confluenceTh">Aufbau</th>
<td class=3D"confluenceTd">
<ul style=3D"list-style-type: square;">
<li>alle Kundenkontakte (Client Services) h=C3=A4ngen an dem Service</li>
</ul></td>
<td class=3D"confluenceTd">
<ul style=3D"list-style-type: square;">
<li>alle infrastrukturellen Komponenten h=C3=A4ngen an dem Service</li>
<li>h=C3=B6here Priorisierung als streamworks prod&nbsp;=E2=86=92 Tickets g=
ehen auf dem Service streamworks prod internal auf</li>
</ul></td>
</tr>
<tr>
<th class=3D"confluenceTh">Einsatzgebiet</th>
<td class=3D"confluenceTd">
<ul style=3D"list-style-type: square;">
<li>f=C3=BCr globale Ank=C3=BCndigungen</li>
<li>wenn Kundeninfos rausgehen sollen</li>
</ul>
<p>=E2=86=92 Bspw. f=C3=BCr Releaseupgrades</p></td>
<td class=3D"confluenceTd">
<ul style=3D"list-style-type: square;">
<li>f=C3=BCr Tickets, die aufgrund von Monitormeldungen aufgehen</li>
<li>f=C3=BCr Changes, die nicht kritisch f=C3=BCr die Kunden sind (ohne Aus=
fall)</li>
</ul></td>
</tr>
<tr>
<th class=3D"confluenceTh">Besonderheit</th>
<td class=3D"confluenceTd">
<ul style=3D"list-style-type: square;">
<li>Komponenten k=C3=B6nnen nicht extra als CI ausgew=C3=A4hlt werden&nbsp;=
=E2=86=92 es reicht sie ggf. unter Scope anzugeben</li>
<li>es muss mit 3-4 Wochen Vorlaufzeit gerechnet werden, da die gro=C3=9Fen=
 Kunden den Change genehmigen m=C3=BCssen</li>
</ul></td>
<td class=3D"confluenceTd">
<ul style=3D"list-style-type: square;">
<li>nur "wir" m=C3=BCssen einen Change mit diesem Service genehmigen</li>
</ul></td>
</tr>
</tbody>
</table>
</div>
<p>Weitere Infos zur Struktur der Services k=C3=B6nnen der UCMDB entnommen =
werden:&nbsp;<a class=3D"external-link" href=3D"https://cm.itsm.arvato-syst=
ems.de/ucmdb-browser/ucmdb_browser.jsp" rel=3D"nofollow">Universal Discover=
y &amp; CMDB (arvato-systems.de)</a></p>
<h1 id=3D"id-00Allgemeines-Teamorganisation-Boards">Boards</h1>
<p>Im HPSM gibt es entsprechende Views zu den in den entsprechenden Boards =
behandelten Themen (Incidents, Changes und Problems). Bitte entsprechend be=
r=C3=BCcksichtigen.</p>
<p><span class=3D"confluence-embedded-file-wrapper confluence-embedded-manu=
al-size"><img class=3D"confluence-embedded-image" height=3D"250" loading=3D=
"lazy" src=3D"dc3487b55630802d74e3e82ee1c13bcbf255494c829e23cde3c251d667b17=
19c" data-image-src=3D"https://arvato-systems-group.atlassian.net/wiki/down=
load/attachments/329746050/hpsm_boards.png?version=3D1&amp;modificationDate=
=3D1564127266068&amp;cacheVersion=3D1&amp;api=3Dv2" data-unresolved-comment=
-count=3D"0" data-linked-resource-id=3D"329749574" data-linked-resource-ver=
sion=3D"1" data-linked-resource-type=3D"attachment" data-linked-resource-de=
fault-alias=3D"hpsm_boards.png" data-base-url=3D"https://arvato-systems-gro=
up.atlassian.net/wiki" data-linked-resource-content-type=3D"image/png" data=
-linked-resource-container-id=3D"329746050" data-linked-resource-container-=
version=3D"57" data-media-id=3D"791c21a5-5b0b-4d79-96a9-eec38ae0e281" data-=
media-type=3D"file" width=3D"106"></span></p>
<h2 id=3D"id-00Allgemeines-Teamorganisation-IncidentBoard">Incident Board</=
h2>
<p><span style=3D"letter-spacing: 0.0px;">Im Incident Board werden alle Inc=
idents mit hoher Kritikalit=C3=A4t der letzten 24h behandelt (sofern der Vo=
rtag ein Werktag war)<br>
Zeitpunkt: Jeden Werktag morgens 09:30 Uhr im Besprechungsraum des Systemop=
erating. <br><br><strong><img class=3D"emoticon emoticon-information" data-=
emoji-id=3D"atlassian-info" data-emoji-shortname=3D":info:" data-emoji-fall=
back=3D":info:" src=3D"26d66e12748dd46b325e81cf74eee14f759950ae60d2fcd4a5bd=
e46b563a1813" width=3D"16" height=3D"16" data-emoticon-name=3D"information"=
 alt=3D"(Info)">&nbsp;Bis auf Weiteres findet das </strong></span><strong><=
a class=3D"external-link" href=3D"https://eur02.safelinks.protection.outloo=
k.com/ap/t-59584e83/?url=3Dhttps%3A%2F%2Fteams.microsoft.com%2Fl%2Fmeetup-j=
oin%2F19%253ameeting_NTg0OTAwM2YtYTNkYy00MWYwLWI4NjQtMzE4ZWJmYzYzMzRj%2540t=
hread.v2%2F0%3Fcontext%3D%257b%2522Tid%2522%253a%25221ca8bd94-3c97-4fc6-895=
5-bad266b43f0b%2522%252c%2522Oid%2522%253a%25220b91c681-aac1-4d88-8f8a-f2cd=
3913a1a2%2522%257d&amp;data=3D02%7C01%7C%7C7f0e0dca6b304c41f45708d82c837bae=
%7C1ca8bd943c974fc68955bad266b43f0b%7C0%7C0%7C637308290728532621&amp;sdata=
=3DI7AuXYGjPQshS1FYv6T9NRj%2FqhVAIewmx95ZGeHYCqU%3D&amp;reserved=3D0" rel=
=3D"nofollow" style=3D"letter-spacing: 0.0px;">Incident Board als Teams-Bes=
prechung</a></strong><span style=3D"letter-spacing: 0.0px;"><strong> statt.=
</strong><br></span></p>
<p>Der Kollege, der jeweils f=C3=BCr den aktuellen Tag das Streamworks-Tage=
sgesch=C3=A4ft betreut, pr=C3=BCft die <a class=3D"external-link" href=3D"h=
ttps://bertelsmann.sharepoint.com/sites/bportal_project_incidentmanagement_=
1384/SitePages/Incidents.aspx?view=3Dintranet" rel=3D"nofollow">Incidents a=
uf der Seite des Incident Boards</a> und nimmt an dem Termin teil, sofern e=
s F=C3=A4lle gibt, die der Responsible Group "Streamworks" zugeordnet sind.=
</p>
<h2 id=3D"id-00Allgemeines-Teamorganisation-DailyCAB(CAB)">Daily CAB (CAB)<=
/h2>
<p>Jeden Werktag im Anschluss an das Incident Board.</p>
<p>Im CAB werden grunds=C3=A4tzliche alle Minor Change besprochen, die im S=
tatus =E2=80=9EDeployment Authorization=E2=80=9C stehen und auf das DCAB Ap=
proval warten. Sofern es Change unserer Seite gibt sollten diese durch uns =
vorgestellt werden.</p>
<h2 id=3D"id-00Allgemeines-Teamorganisation-ManagementChangeAdvisoryBoard(M=
CAB)">Management Change Advisory Board (MCAB)</h2>
<p>Jeden Dienstag und Donnerstag im DC1 Softwaregeb=C3=A4ude findet das MCA=
B im Besprechungsraum 0.06 bzw. 0.08 von 14:30 - 15:30 Uhr statt. Vorstellu=
ng aller MCAB relevanten Changes (die Critical Components enthalten oder al=
s Major klassifiziert), die im Status "Request Approval" sind.&nbsp;</p>
<p>Im MCAB werden alle Major / Major Global Change besprochen, die auf das =
MCAB Approval warten.</p>
<p><img class=3D"emoticon emoticon-information" data-emoji-id=3D"atlassian-=
info" data-emoji-shortname=3D":info:" data-emoji-fallback=3D":info:" src=3D=
"26d66e12748dd46b325e81cf74eee14f759950ae60d2fcd4a5bde46b563a1813" width=3D=
"16" height=3D"16" data-emoticon-name=3D"information" alt=3D"(Info)">&nbsp;=
Regelm=C3=A4=C3=9Fige Teilnahme ist durch Guido, Christoph und Ren=C3=A9 ab=
gedeckt (Rotation). Bei einem Change aus unserem Bereich in der Regel Vorst=
ellung im MCAB durch Ren=C3=A9. Ansonsten sollten die anderen Kollegen vora=
b =C3=BCber einen Change aus unserem Bereich informiert werden.</p>
<p><img class=3D"emoticon emoticon-information" data-emoji-id=3D"atlassian-=
info" data-emoji-shortname=3D":info:" data-emoji-fallback=3D":info:" src=3D=
"26d66e12748dd46b325e81cf74eee14f759950ae60d2fcd4a5bde46b563a1813" width=3D=
"16" height=3D"16" data-emoticon-name=3D"information" alt=3D"(Info)"> Regel=
n Change Management:&nbsp;<a href=3D"/wiki/spaces/sysop/pages/239344203" da=
ta-linked-resource-id=3D"239344203" data-linked-resource-version=3D"18" dat=
a-linked-resource-type=3D"page">/wiki/spaces/sysop/pages/239344203</a>.&nbs=
p;</p>
<h2 id=3D"id-00Allgemeines-Teamorganisation-EmergencyBoard(ECAB)">Emergency=
 Board (ECAB)</h2>
<p>Kein fester Termin. Im Falle eines dringenden Emergency Changes wird der=
 Change nach R=C3=BCcksprache von MoC (Manager on Call) freigegeben. Wer ak=
tuell MoC ist kann =C3=BCber das Systemoperating in Erfahrung gebracht werd=
en.</p>
<h2 id=3D"id-00Allgemeines-Teamorganisation-ProblemAdvisoryBoard(PAB)">Prob=
lem Advisory Board (PAB)</h2>
<p>Freitags im Anschluss an Incident Board und CAB.</p>
<p>Im PAB werden alle neuen Problemtickets besprochen, sowie Problems, dess=
en Expected Resolution Date abgelaufen ist und Problems, die geschlossen wu=
rden. Am Problemboard m=C3=BCssen nur Teams teilnehmen die aktuell Problemt=
ickets zugewiesen haben. Es erfolgt eine separate Einladung dazu durch die =
Prod. Leitung.</p>
<h2 id=3D"id-00Allgemeines-Teamorganisation-M24Board">M24 Board</h2>
<p>T=C3=A4glich werktags im DC3 3.81 um 08:45 Uhr. Es werden St=C3=B6rungen=
 des letzten Tages und der letzten Nacht besprochen. Findet bis auf Weitere=
s per Teams-Besprechung statt. Teilnahme durch Guido, Stefan und Ren=C3=A9 =
(Rotation) abgedeckt.</p>
<p><br></p>
<h1 id=3D"id-00Allgemeines-Teamorganisation-Auftragsnummern">Auftragsnummer=
n</h1>
<p>Eine zentrale =C3=9Cbersicht der wichtigsten Auftragsnummern, speziell f=
=C3=BCr die Streamworks Releaseentwicklung, Testing, Kundensupport etc. bef=
indet sich im Streamworks Sharepoint hier:&nbsp;<a class=3D"external-link" =
href=3D"https://bertelsmann.sharepoint.com/sites/bportal_asys02_Streamworks=
Dev_014397/2%20Project%20Reporting/200%20Auftragsnummern/Streamworks_Taetig=
keiten_Auftragsnummern.xlsx?d=3Dw25f5282a56f642c89ee36cf4d8573f9c&amp;csf=
=3D1&amp;web=3D1&amp;e=3DHkPbf9" rel=3D"nofollow">https://bertelsmann.share=
point.com/sites/bportal_asys02_StreamworksDev_014397/_layouts/15/guestacces=
s.aspx?guestaccesstoken=3DP2R%2FyyeHQ9pNvLfY4FCRAqSTxUaXp6AFKEibSCvjNiY%3D&=
amp;docid=3D2_025f5282a56f642c89ee36cf4d8573f9c&amp;rev=3D1&amp;e=3D6uUCAL<=
/a></p>
<p>Falls der Link nicht funktioniert ist das Dokument im Streamworks Dev Sh=
arepoint unter Documents&nbsp;=E2=86=92 2 Project Reporting&nbsp;=E2=86=92 =
200 Auftragsnummern zu finden.</p>
<p><span class=3D"confluence-embedded-file-wrapper confluence-embedded-manu=
al-size"><img class=3D"confluence-embedded-image" height=3D"229" loading=3D=
"lazy" src=3D"ee6e4918e8b0195e88f38eeafc88aec6166fabffacc1550aaf36fdb5954e3=
d43" data-image-src=3D"https://arvato-systems-group.atlassian.net/wiki/down=
load/attachments/329746050/image2021-5-5_18-14-37.png?version=3D1&amp;modif=
icationDate=3D1620231277986&amp;cacheVersion=3D1&amp;api=3Dv2" data-unresol=
ved-comment-count=3D"0" data-linked-resource-id=3D"329758078" data-linked-r=
esource-version=3D"1" data-linked-resource-type=3D"attachment" data-linked-=
resource-default-alias=3D"image2021-5-5_18-14-37.png" data-base-url=3D"http=
s://arvato-systems-group.atlassian.net/wiki" data-linked-resource-content-t=
ype=3D"image/png" data-linked-resource-container-id=3D"329746050" data-link=
ed-resource-container-version=3D"57" data-media-id=3D"d11a4d9e-9461-4c35-8c=
c3-2f3904eaaa47" data-media-type=3D"file" width=3D"468"></span></p>
<p><br></p>
<p>Eine =C3=9Cbersicht aller internen ANR befindet sich zudem im Wiki der S=
treamworks Services Kollegen: =E2=86=92&nbsp;<a href=3D"/wiki/spaces/prodct=
rl/pages/316932650" data-linked-resource-id=3D"316932650" data-linked-resou=
rce-version=3D"66" data-linked-resource-type=3D"page">/wiki/spaces/prodctrl=
/pages/316932650</a></p>
<p><br></p>
<p>Sollte f=C3=BCr bestimmte T=C3=A4tigkeiten vom Anforderer eine Auftragsn=
ummer mitgeschickt werden, beispielsweise f=C3=BCr ein bestimmtes Projekt, =
dann den Aufwand auf diesen Auftrag buchen.</p>
<p>F=C3=BCr Anforderungen die nicht zum normales Tagesgesch=C3=A4ft passen =
(beispielsweise Anfragen von UMGI zur Vistex/AWS Umgebung) sollte eine Auft=
ragsnummer vom Anforderer angefordert werden.&nbsp; Im Zweifel Ren=C3=A9 fr=
agen.</p>
<p>### Hier noch Ren=C3=A9s Info zu den CATS-Buchungsnummern einf=C3=BCgen/=
 erg=C3=A4nzen - scwi036</p>
<p>Folgende Leistungsarten sind f=C3=BCr uns aktuell relevant:</p>
<ul>
<li>10873 - Systemingenieur: Tagesgesch=C3=A4ft, PAO Support, Betriebstheme=
n rund um die Produktion</li>
<li>10896 - Systemarchitekt: "H=C3=B6herwertige T=C3=A4tigkeiten". Design n=
euer Architekturen,&nbsp;Anforderungsmanagement (RSD Erstellung, Review, DD=
D Review etc.), Koordination Security (GAP Aufnahme, DSGVO, etc.), Anforder=
ungsmanagement im Bereich Order Management OMM (=C3=84nderung an den Workfl=
ows, Koordination mit Entwicklung, Test, Abnahme. )</li>
</ul>
<p>Weitere Auftragsnummern gibt es f=C3=BCr Rufbereitschaften oder Sonn- un=
d Feiertagsarbeit. Siehe&nbsp;<a href=3D"/wiki/spaces/PRODTBS/pages/3172928=
20" data-linked-resource-id=3D"317292820" data-linked-resource-version=3D"2=
40" data-linked-resource-type=3D"page">/wiki/spaces/PRODTBS/pages/317292820=
</a></p>
<p>&nbsp;<img class=3D"emoticon emoticon-information" data-emoji-id=3D"atla=
ssian-info" data-emoji-shortname=3D":info:" data-emoji-fallback=3D":info:" =
src=3D"26d66e12748dd46b325e81cf74eee14f759950ae60d2fcd4a5bde46b563a1813" wi=
